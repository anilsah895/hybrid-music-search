# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

.venv/
venv/
env/

*.egg-info/
dist/
build/

# -------------------------
# Environment variables (IMPORTANT)
# -------------------------
.env
.env.*
!.env.example   # allow example file for reviewers

# -------------------------
# IDE / Editor
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Logs
# -------------------------
*.log

# -------------------------
# Testing / Coverage
# -------------------------
.pytest_cache/
.coverage
htmlcov/

# -------------------------
# Alembic
# -------------------------
alembic/versions/__pycache__/
alembic/versions/*.pyc

# -------------------------
# Local data / datasets
# -------------------------
data/
*.jsonl
*.csv
*.parquet

# (IMPORTANT tweak)
!data/sample.json   # optional: keep tiny seed sample if needed

# -------------------------
# Docker / runtime artifacts
# -------------------------
*.pid

# -------------------------
# Databases / local state
# -------------------------
*.db
*.sqlite
*.sqlite3

# -------------------------
# Temporary files
# -------------------------
tmp/
temp/